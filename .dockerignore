**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/venv/
**/.venv/
**/env/

# Node.js
**/node_modules/
**/dist/
**/npm-debug.log*

# Java
**/target/
**/*.class
**/*.jar

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Project Specific
**/data/
**/tmp/
**/logs/
**/uploadfile/
**/mysql/data/

# Docker
docker-compose*.yml
.env
Dockerfile*
!Dockerfile-web
!Dockerfile-server